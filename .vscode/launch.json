        },
        {
            "name": "Run Ablation: no m",
            "type": "debugpy",
            "request": "launch",
            "module": "src.run_simulation",
            "args": ["--config", "configs/ablation_no_m.yaml"],
            "cwd": "${workspaceFolder}"
        }
    ]
}
